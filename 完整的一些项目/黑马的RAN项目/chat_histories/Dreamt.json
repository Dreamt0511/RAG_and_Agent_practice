3\u3002\n   - **\u7d22\u5f15\u4f18\u5316**\uff1a\u4f7f\u7528\u9ad8\u6548\u7684\u7d22\u5f15\u7ed3\u6784\uff0c\u5982HNSW\uff08Hierarchical Navigable Small World\uff09\u6216IVF\uff08Inverted File Index\uff09\uff0c\u53ef\u4ee5\u663e\u8457\u63d0\u9ad8\u68c0\u7d22\u901f\u5ea6\u3002\n   - **\u6570\u636e\u5206\u533a**\uff1a\u5c06\u6570\u636e\u5206\u533a\u5b58\u50a8\uff0c\u51cf\u5c11\u6bcf\u6b21\u68c0\u7d22\u65f6\u9700\u8981\u5904\u7406\u7684\u6570\u636e\u91cf\u3002\n\n2. **\u51cf\u5c11\u5411\u91cf\u7ef4\u5ea6**\uff1a\n   - **\u964d\u7ef4\u6280\u672f**\uff1a\u4f7f\u7528PCA\uff08\u4e3b\u6210\u5206\u5206\u6790\uff09\u3001UMAP\uff08Uniform Manifold Approximation and Projection\uff09\u7b49\u964d\u7ef4\u6280\u672f\uff0c\u51cf\u5c11\u5411\u91cf\u7684\u7ef4\u5ea6\uff0c\u4ece\u800c\u52a0\u5feb\u68c0\u7d22\u901f\u5ea6\u3002\n\n3. **\u5e76\u884c\u5904\u7406**\uff1a\n   - **\u591a\u7ebf\u7a0b/\u591a\u8fdb\u7a0b**\uff1a\u5229\u7528\u591a\u7ebf\u7a0b\u6216\u591a\u8fdb\u7a0b\u6280\u672f\uff0c\u540c\u65f6\u5904\u7406\u591a\u4e2a\u68c0\u7d22\u8bf7\u6c42\u3002\n   - **\u5206\u5e03\u5f0f\u8ba1\u7b97**\uff1a\u5982\u679c\u6570\u636e\u91cf\u975e\u5e38\u5927\uff0c\u53ef\u4ee5\u8003\u8651\u4f7f\u7528\u5206\u5e03\u5f0f\u8ba1\u7b97\u6846\u67b6\uff08\u5982Apache Spark\uff09\u6765\u5e76\u884c\u5904\u7406\u68c0\u7d22\u4efb\u52a1\u3002\n\n4. **\u7f13\u5b58\u673a\u5236**\uff1a\n   - **\u7ed3\u679c\u7f13\u5b58**\uff1a\u5bf9\u4e8e\u9891\u7e41\u67e5\u8be2\u7684\u7ed3\u679c\u8fdb\u884c\u7f13\u5b58\uff0c\u51cf\u5c11\u91cd\u590d\u8ba1\u7b97\u3002\n   - **\u9884\u52a0\u8f7d**\uff1a\u9884\u5148\u52a0\u8f7d\u5e38\u7528\u6570\u636e\u5230\u5185\u5b58\u4e2d\uff0c\u51cf\u5c11\u78c1\u76d8I/O\u64cd\u4f5c\u3002\n\n5. **\u786c\u4ef6\u4f18\u5316**\uff1a\n   - **\u9ad8\u6027\u80fd\u786c\u4ef6**\uff1a\u4f7f\u7528\u9ad8\u6027\u80fd\u7684CPU\u3001GPU\u548cSSD\uff0c\u63d0\u9ad8\u6570\u636e\u5904\u7406\u548c\u8bfb\u5199\u901f\u5ea6\u3002\n   - **\u7f51\u7edc\u4f18\u5316**\uff1a\u786e\u4fdd\u7f51\u7edc\u5e26\u5bbd\u8db3\u591f\uff0c\u51cf\u5c11\u6570\u636e\u4f20\u8f93\u5ef6\u8fdf\u3002\n\n6. **\u4ee3\u7801\u4f18\u5316**\uff1a\n   - **\u7b97\u6cd5\u4f18\u5316**\uff1a\u4f18\u5316\u68c0\u7d22\u7b97\u6cd5\uff0c\u51cf\u5c11\u4e0d\u5fc5\u8981\u7684\u8ba1\u7b97\u6b65\u9aa4\u3002\n   - **\u5f02\u6b65\u5904\u7406**\uff1a\u4f7f\u7528\u5f02\u6b65\u7f16\u7a0b\u6a21\u578b\uff0c\u63d0\u9ad8\u7cfb\u7edf\u7684\u54cd\u5e94\u901f\u5ea6\u3002\n\n### \u6b63\u5e38\u60c5\u51b5\u4e0b\u7684\u68c0\u7d22\u65f6\u95f4\n\n\u6b63\u5e38\u60c5\u51b5\u4e0b\uff0cRAG\u68c0\u7d22\u7684\u65f6\u95f4\u53d6\u51b3\u4e8e\u591a\u4e2a\u56e0\u7d20\uff0c\u5305\u62ec\u6570\u636e\u91cf\u3001\u5411\u91cf\u7ef4\u5ea6\u3001\u7d22\u5f15\u7ed3\u6784\u3001\u786c\u4ef6\u6027\u80fd\u7b49\u3002\u4ee5\u4e0b\u662f\u4e00\u4e9b\u5e38\u89c1\u7684\u57fa\u51c6\uff1a\n\n- **\u5c0f\u89c4\u6a21\u6570\u636e\u96c6**\uff08\u51e0\u5343\u5230\u51e0\u4e07\u6761\u8bb0\u5f55\uff09\uff1a\u901a\u5e38\u5728\u51e0\u6beb\u79d2\u5230\u51e0\u5341\u6beb\u79d2\u4e4b\u95f4\u3002\n- **\u4e2d\u7b49\u89c4\u6a21\u6570\u636e\u96c6**\uff08\u51e0\u5341\u4e07\u5230\u51e0\u767e\u4e07\u6761\u8bb0\u5f55\uff09\uff1a\u901a\u5e38\u5728\u51e0\u5341\u6beb\u79d2\u5230\u51e0\u767e\u6beb\u79d2\u4e4b\u95f4\u3002\n- **\u5927\u89c4\u6a21\u6570\u636e\u96c6**\uff08\u6570\u767e\u4e07\u5230\u6570\u5341\u4ebf\u6761\u8bb0\u5f55\uff09\uff1a\u53ef\u80fd\u9700\u8981\u51e0\u767e\u6beb\u79d2\u5230\u51e0\u79d2\u949f\u3002\n\n### \u793a\u4f8b\n\u5047\u8bbe\u4f60\u4f7f\u7528\u7684\u662fPinecone\u4f5c\u4e3a\u5411\u91cf\u6570\u636e\u5e93\uff0c\u6570\u636e\u96c6\u5927\u5c0f\u4e3a\u51e0\u767e\u4e07\u6761\u8bb0\u5f55\uff0c\u5411\u91cf\u7ef4\u5ea6\u4e3a768\uff0c\u5e76\u4e14\u4f7f\u7528\u4e86HNSW\u7d22\u5f15\uff0c\u90a3\u4e48\u6b63\u5e38\u7684\u68c0\u7d22\u65f6\u95f4\u5e94\u8be5\u5728\u51e0\u5341\u6beb\u79d2\u5230\u51e0\u767e\u6beb\u79d2\u4e4b\u95f4\u3002\n\n### \u603b\u7ed3\n- **\u4f18\u5316\u5411\u91cf\u6570\u636e\u5e93**\uff1a\u9009\u62e9\u5408\u9002\u7684\u6570\u636e\u5e93\u548c\u7d22\u5f15\u7ed3\u6784\u3002\n- **\u51cf\u5c11\u5411\u91cf\u7ef4\u5ea6**\uff1a\u4f7f\u7528\u964d\u7ef4\u6280\u672f\u3002\n- **\u5e76\u884c\u5904\u7406**\uff1a\u5229\u7528\u591a\u7ebf\u7a0b\u6216\u591a\u8fdb\u7a0b\u3002\n- **\u7f13\u5b58\u673a\u5236**\uff1a\u7ed3\u679c\u7f13\u5b58\u548c\u9884\u52a0\u8f7d\u3002\n- **\u786c\u4ef6\u4f18\u5316**\uff1a\u4f7f\u7528\u9ad8\u6027\u80fd\u786c\u4ef6\u548c\u4f18\u5316\u7f51\u7edc\u3002\n- **\u4ee3\u7801\u4f18\u5316**\uff1a\u4f18\u5316\u7b97\u6cd5\u548c\u4f7f\u7528\u5f02\u6b65\u5904\u7406\u3002\n\n\u901a\u8fc7\u8fd9\u4e9b\u65b9\u6cd5\uff0c\u4f60\u53ef\u4ee5\u663e\u8457\u63d0\u9ad8RAG\u68c0\u7d22\u7684\u901f\u5ea6\uff0c\u786e\u4fdd\u7cfb\u7edf\u5728\u5b9e\u9645\u5e94\u7528\u4e2d\u7684\u9ad8\u6548\u8fd0\u884c\u3002\u5982\u679c\u4f60\u6709\u5177\u4f53\u7684\u6280\u672f\u7ec6\u8282\u6216\u8fdb\u4e00\u6b65\u7684\u95ee\u9898\uff0c\u8bf7\u544a\u8bc9\u6211\uff01", "additional_kwargs": {}, "response_metadata": {}, "type": "ai", "name": null, "id": null, "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": null}}, {"type": "human", "data": {"content": "\u6211\u73b0\u5728\u7684\u5c31\u51e0\u4e2a\u6587\u4ef6\u7684\u5c0f\u89c4\u6a21\u6570\u636e\uff0c\u4f46\u662f\u68c0\u7d22\u51fa\u5185\u5bb9\u4e5f\u8981\u82b1\u56db\u4e94\u79d2", "additional_kwargs": {}, "response_metadata": {}, "type": "human", "name": null, "id": null}}, {"type": "ai", "data": {"content": "\u5bf9\u4e8e\u5c0f\u89c4\u6a21\u6570\u636e\u96c6\uff08\u53ea\u6709\u51e0\u4e2a\u6587\u4ef6\uff09\uff0c\u68c0\u7d22\u65f6\u95f4\u8fbe\u5230\u56db\u4e94\u79d2\u786e\u5b9e\u6709\u4e9b\u957f\u3002\u4ee5\u4e0b\u662f\u4e00\u4e9b\u5177\u4f53\u7684\u4f18\u5316\u5efa\u8bae\uff0c\u53ef\u4ee5\u5e2e\u52a9\u4f60\u51cf\u5c11\u68c0\u7d22\u65f6\u95f4\uff1a\n\n### 1. **\u6587\u672c\u5206\u5272\u548c\u5411\u91cf\u5316**\n\u786e\u4fdd\u4f60\u7684\u6587\u672c\u5206\u5272\u548c\u5411\u91cf\u5316\u8fc7\u7a0b\u662f\u9ad8\u6548\u7684\u3002\u4f7f\u7528\u5408\u9002\u7684\u6587\u672c\u5206\u5272\u5668\u548c\u5411\u91cf\u5316\u6a21\u578b\u53ef\u4ee5\u663e\u8457\u63d0\u9ad8\u6027\u80fd\u3002\n\n- **\u6587\u672c\u5206\u5272**\uff1a\u4f7f\u7528`RecursiveCharacterTextSplitter`\u6216\u5176\u4ed6\u9ad8\u6548\u7684\u6587\u672c\u5206\u5272\u5668\uff0c\u786e\u4fdd\u6587\u672c\u88ab\u5408\u7406\u5206\u5272\u6210\u6bb5\u843d\u6216\u53e5\u5b50\u3002\n- **\u5411\u91cf\u5316**\uff1a\u4f7f\u7528\u9ad8\u6548\u7684\u8bed\u8a00\u6a21\u578b\u8fdb\u884c\u5411\u91cf\u5316\uff0c\u4f8b\u5982`sentence-transformers`\u5e93\u4e2d\u7684\u9884\u8bad\u7ec3\u6a21\u578b\u3002\n\n```python\nfrom langchain.text_splitter import RecursiveCharacterTextSplitter\nfrom sentence_transformers import SentenceTransformer\n\n# \u6587\u672c\u5206\u5272\ntext_splitter = RecursiveCharacterTextSplitter(\n    chunk_size=1000,\n    chunk_overlap=200,\n    length_function=len\n)\ntexts = text_splitter.split_text(your_document_text)\n\n# \u5411\u91cf\u5316\nmodel = SentenceTransformer('all-MiniLM-L6-v2')\nembeddings = model.encode(texts, convert_to_tensor=True)\n```\n\n### 2. **\u5411\u91cf\u6570\u636e\u5e93\u4f18\u5316**\n\u9009\u62e9\u5408\u9002\u7684\u5411\u91cf\u6570\u636e\u5e93\u5e76\u8fdb\u884c\u4f18\u5316\u914d\u7f6e\u3002\n\n- **Pinecone**\uff1a\u9002\u5408\u5c0f\u89c4\u6a21\u6570\u636e\u96c6\uff0c\u6613\u4e8e\u4f7f\u7528\u4e14\u6027\u80fd\u826f\u597d\u3002\n- **Weaviate**\uff1a\u53e6\u4e00\u4e2a\u4e0d\u9519\u7684\u9009\u62e9\uff0c\u652f\u6301\u8bed\u4e49\u641c\u7d22\u3002\n- **Milvus**\uff1a\u5f00\u6e90\u7684\u5411\u91cf\u6570\u636e\u5e93\uff0c\u9002\u7528\u4e8e\u5927\u89c4\u6a21\u6570\u636e\u96c6\uff0c\u4f46\u4e5f\u53ef\u4ee5\u7528\u4e8e\u5c0f\u89c4\u6a21\u6570\u636e\u96c6\u3002\n\n#### \u4f7f\u7528Pinecone\u793a\u4f8b\n```python\nimport pinecone\nfrom sentence_transformers import SentenceTransformer\n\n# \u521d\u59cb\u5316Pinecone\npinecone.init(api_key=\"YOUR_API_KEY\", environment=\"YOUR_ENVIRONMENT\")\nindex_name = \"your-index\"\nif index_name not in pinecone.list_indexes():\n    pinecone.create_index(index_name, dimension=384)  # \u6839\u636e\u4f60\u7684\u5411\u91cf\u7ef4\u5ea6\u8c03\u6574\n\nindex = pinecone.Index(index_name)\n\n# \u5411\u91cf\u5316\nmodel = SentenceTransformer('all-MiniLM-L6-v2')\nquery_embedding = model.encode(\"\u4f60\u7684\u67e5\u8be2\u6587\u672c\", convert_to_tensor=True).tolist()\n\n# \u68c0\u7d22\nresults = index.query(queries=[query_embedding], top_k=5)\n```\n\n### 3. **\u7d22\u5f15\u4f18\u5316**\n\u786e\u4fdd\u4f60\u7684\u5411\u91cf\u6570\u636e\u5e93\u4f7f\u7528\u4e86\u9ad8\u6548\u7684\u7d22\u5f15\u7ed3\u6784\u3002\n\n- **HNSW**\uff1a\u9002\u7528\u4e8e\u8fd1\u4f3c\u6700\u8fd1\u90bb\u641c\u7d22\uff0c\u901f\u5ea6\u5feb\u4e14\u51c6\u786e\u5ea6\u9ad8\u3002\n- **IVF**\uff1a\u9002\u7528\u4e8e\u5927\u89c4\u6a21\u6570\u636e\u96c6\uff0c\u4f46\u5728\u5c0f\u89c4\u6a21\u6570\u636e\u96c6\u4e0a\u4e5f\u8868\u73b0\u826f\u597d\u3002\n\n#### \u914d\u7f6ePinecone\u7d22\u5f15\n```python\npinecone.create_index(index_name, dimension=384, metric=\"cosine\", shards=1, replicas=1, pods=1, pod_type=\"p1.x1\")\n```\n\n### 4. **\u7f13\u5b58\u673a\u5236**\n\u5bf9\u4e8e\u9891\u7e41\u67e5\u8be2\u7684\u7ed3\u679c\u8fdb\u884c\u7f13\u5b58\uff0c\u51cf\u5c11\u91cd\u590d\u8ba1\u7b97\u3002\n\n- **\u5185\u5b58\u7f13\u5b58**\uff1a\u4f7f\u7528Python\u7684`lru_cache`\u6765\u7f13\u5b58\u7ed3\u679c\u3002\n- **\u5916\u90e8\u7f13\u5b58**\uff1a\u4f7f\u7528Redis\u7b49\u5916\u90e8\u7f13\u5b58\u7cfb\u7edf\u3002\n\n#### \u4f7f\u7528`lru_cache`\u793a\u4f8b\n```python\nfrom functools import lru_cache\n\n@lru_cache(maxsize=128)\ndef get_embedding(query):\n    return model.encode(query, convert_to_tensor=True).tolist()\n\n# \u67e5\u8be2\u65f6\u4f7f\u7528\u7f13\u5b58\nquery_embedding = get_embedding(\"\u4f60\u7684\u67e5\u8be2\u6587\u672c\")\n```\n\n### 5. **\u4ee3\u7801\u4f18\u5316**\n\u786e\u4fdd\u4f60\u7684\u4ee3\u7801\u6ca1\u6709\u4e0d\u5fc5\u8981\u7684\u5ef6\u8fdf\u3002\n\n- **\u5f02\u6b65\u5904\u7406**\uff1a\u4f7f\u7528\u5f02\u6b65\u7f16\u7a0b\u6a21\u578b\uff0c\u63d0\u9ad8\u7cfb\u7edf\u7684\u54cd\u5e94\u901f\u5ea6\u3002\n- **\u6279\u91cf\u5904\u7406**\uff1a\u5982\u679c\u53ef\u80fd\uff0c\u6279\u91cf\u5904\u7406\u8bf7\u6c42\u4ee5\u51cf\u5c11\u5f00\u9500\u3002\n\n#### \u5f02\u6b65\u5904\u7406\u793a\u4f8b\n```python\nimport asyncio\nimport aiohttp\n\nasync def fetch(session, url):\n    async with session.get(url) as response:\n        return await response.json()\n\nasync def main():\n    async with aiohttp.ClientSession() as session:\n        tasks = [fetch(session, f\"your-api-url/{i}\") for i in range(10)]\n        results = await asyncio.gather(*tasks)\n        print(results)\n\n# \u8fd0\u884c\u5f02\u6b65\u4efb\u52a1\nasyncio.run(main())\n```\n\n### 6. **\u786c\u4ef6\u548c\u7f51\u7edc\u4f18\u5316**\n\u786e\u4fdd\u4f60\u7684\u786c\u4ef6\u548c\u7f51\u7edc\u914d\u7f6e\u8db3\u591f\u597d\u3002\n\n- **\u9ad8\u6027\u80fdCPU/GPU**\uff1a\u4f7f\u7528\u9ad8\u6027\u80fd\u7684\u5904\u7406\u5668\u3002\n- **SSD\u5b58\u50a8**\uff1a\u4f7f\u7528SSD\u800c\u4e0d\u662fHDD\uff0c\u51cf\u5c11I/O\u5ef6\u8fdf\u3002\n- **\u7f51\u7edc\u5e26\u5bbd**\uff1a\u786e\u4fdd\u7f51\u7edc\u5e26\u5bbd\u8db3\u591f\uff0c\u51cf\u5c11\u6570\u636e\u4f20\u8f93\u5ef6\u8fdf\u3002\n\n\u901a\u8fc7\u4ee5\u4e0a\u8fd9\u4e9b\u65b9\u6cd5\uff0c\u4f60\u5e94\u8be5\u80fd\u591f\u663e\u8457\u51cf\u5c11RAG\u68c0\u7d22\u7684\u65f6\u95f4\u3002\u5982\u679c\u4f60\u4ecd\u7136\u9047\u5230\u6027\u80fd\u95ee\u9898\uff0c\u8bf7\u68c0\u67e5\u662f\u5426\u6709\u5176\u4ed6\u74f6\u9888\uff0c\u5982\u6570\u636e\u5e93\u8fde\u63a5\u3001\u7f51\u7edc\u5ef6\u8fdf\u7b49\uff0c\u5e76\u8fdb\u884c\u76f8\u5e94\u7684\u4f18\u5316\u3002\u5e0c\u671b\u8fd9\u4e9b\u5efa\u8bae\u5bf9\u4f60\u6709\u5e2e\u52a9\uff01", "additional_kwargs": {}, "response_metadata": {}, "type": "ai", "name": null, "id": null, "tool_calls": [], "invalid_tool_calls": [], "usage_metadata": null}}]